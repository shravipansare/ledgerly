generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
}

enum Role {
  OWNER
  ADMIN
  ACCOUNTANT
  MANAGER
  VIEWER
}

enum InvoiceStatus {
  DRAFT
  PENDING
  SENT
  VIEWED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum PaymentMethod {
  ONLINE
  UPI
  BANK_TRANSFER
  CARD
  CASH
}

enum ExpenseCategory {
  SOFTWARE
  MARKETING
  SALARY
  UTILITIES
  OFFICE
  TRAVEL
  OTHER
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      Role     @default(OWNER)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  invoices  Invoice[]
  clients   Client[]
  products  Product[]
  expenses  Expense[]
}

model Client {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  email           String
  phone           String?
  gstNumber       String?
  panNumber       String?
  billingAddress  String?
  shippingAddress String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  userId    String    @db.ObjectId
  user      User      @relation(fields: [userId], references: [id])
  invoices  Invoice[]
  payments  Payment[]
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  sku         String?  @unique
  price       Float
  taxCategory String?
  unit        String?  @default("unit")
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userId      String        @db.ObjectId
  user        User          @relation(fields: [userId], references: [id])
  invoiceItems InvoiceItem[]
}

model Invoice {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  invoiceNumber String        @unique
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  subtotal      Float
  taxTotal      Float
  total         Float
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  userId       String        @db.ObjectId
  user         User          @relation(fields: [userId], references: [id])
  clientId     String        @db.ObjectId
  client       Client        @relation(fields: [clientId], references: [id])
  items        InvoiceItem[]
  payments     Payment[]
}

model InvoiceItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  quantity    Float    @default(1)
  unitPrice   Float
  total       Float
  description String?

  // Relations
  invoiceId   String   @db.ObjectId
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?  @db.ObjectId
  product     Product? @relation(fields: [productId], references: [id])
}

model Payment {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  amount        Float
  paymentDate   DateTime      @default(now())
  method        PaymentMethod
  referenceId   String?
  notes         String?
  createdAt     DateTime      @default(now())

  // Relations
  invoiceId     String        @db.ObjectId
  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  clientId      String        @db.ObjectId
  client        Client        @relation(fields: [clientId], references: [id])
}

model Expense {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  amount      Float
  date        DateTime        @default(now())
  category    ExpenseCategory @default(OTHER)
  merchant    String?
  description String?
  receiptUrl  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  userId      String          @db.ObjectId
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}
