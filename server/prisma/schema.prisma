generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

enum Role {
  OWNER
  ADMIN
  ACCOUNTANT
  MANAGER
  VIEWER
}

enum InvoiceStatus {
  DRAFT
  PENDING
  SENT
  VIEWED
  PARTIALLY_PAID
  PAID
  OVERDUE
  CANCELLED
  REFUNDED
}

enum QuotationStatus {
  DRAFT
  SENT
  VIEWED
  ACCEPTED
  REJECTED
  EXPIRED
}

enum PaymentMethod {
  ONLINE
  UPI
  BANK_TRANSFER
  CARD
  CASH
}

enum ExpenseCategory {
  SOFTWARE
  MARKETING
  SALARY
  UTILITIES
  OFFICE
  TRAVEL
  OTHER
}

model User {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  email     String   @unique
  password  String
  firstName String
  lastName  String
  role      Role     @default(OWNER)
  resetPasswordToken   String?
  resetPasswordExpires DateTime?
  companyName    String?
  companyAddress String?
  companyPhone   String?
  companyTaxId   String?
  companyLogo    String?
  
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  // Relations
  invoices   Invoice[]
  quotations Quotation[]
  clients    Client[]
  products   Product[]
  expenses   Expense[]
  taxes      TaxRate[]
}

model Client {
  id              String   @id @default(auto()) @map("_id") @db.ObjectId
  name            String
  email           String
  phone           String?
  gstNumber       String?
  panNumber       String?
  billingAddress  String?
  shippingAddress String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relations
  userId     String      @db.ObjectId
  user       User        @relation(fields: [userId], references: [id])
  invoices   Invoice[]
  quotations Quotation[]
  payments   Payment[]
}

model Product {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  sku         String?  @unique
  price       Float
  taxCategory String?
  unit        String?  @default("unit")
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  userId        String          @db.ObjectId
  user          User            @relation(fields: [userId], references: [id])
  invoiceItems  InvoiceItem[]
  quotationItems QuotationItem[]
}

model Invoice {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  invoiceNumber String        @unique
  status        InvoiceStatus @default(DRAFT)
  issueDate     DateTime      @default(now())
  dueDate       DateTime
  subtotal      Float
  taxTotal      Float
  total         Float
  notes         String?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  // Relations
  userId       String        @db.ObjectId
  user         User          @relation(fields: [userId], references: [id])
  clientId     String        @db.ObjectId
  client       Client        @relation(fields: [clientId], references: [id])
  items        InvoiceItem[]
  payments     Payment[]
}

model InvoiceItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  quantity    Float    @default(1)
  unitPrice   Float
  total       Float
  description String?
  
  // Advanced Taxes
  appliedTaxName String?
  appliedTaxRate Float?

  // Relations
  invoiceId   String   @db.ObjectId
  invoice     Invoice  @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  productId   String?  @db.ObjectId
  product     Product? @relation(fields: [productId], references: [id])
}

model Payment {
  id            String        @id @default(auto()) @map("_id") @db.ObjectId
  amount        Float
  paymentDate   DateTime      @default(now())
  method        PaymentMethod
  referenceId   String?
  notes         String?
  createdAt     DateTime      @default(now())

  // Relations
  invoiceId     String        @db.ObjectId
  invoice       Invoice       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  clientId      String        @db.ObjectId
  client        Client        @relation(fields: [clientId], references: [id])
}

model Expense {
  id          String          @id @default(auto()) @map("_id") @db.ObjectId
  amount      Float
  date        DateTime        @default(now())
  category    ExpenseCategory @default(OTHER)
  merchant    String?
  description String?
  receiptUrl  String?
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @updatedAt

  // Relations
  userId      String          @db.ObjectId
  user        User            @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model TaxRate {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  name        String
  rate        Float
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  userId      String   @db.ObjectId
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Quotation {
  id            String          @id @default(auto()) @map("_id") @db.ObjectId
  quotationNumber String        @unique
  status        QuotationStatus @default(DRAFT)
  issueDate     DateTime        @default(now())
  validUntil    DateTime
  subtotal      Float
  taxTotal      Float
  total         Float
  notes         String?
  createdAt     DateTime        @default(now())
  updatedAt     DateTime        @updatedAt

  // Relations
  userId       String          @db.ObjectId
  user         User            @relation(fields: [userId], references: [id])
  clientId     String          @db.ObjectId
  client       Client          @relation(fields: [clientId], references: [id])
  items        QuotationItem[]
}

model QuotationItem {
  id          String   @id @default(auto()) @map("_id") @db.ObjectId
  quantity    Float    @default(1)
  unitPrice   Float
  total       Float
  description String?
  
  // Advanced Taxes
  appliedTaxName String?
  appliedTaxRate Float?

  // Relations
  quotationId String    @db.ObjectId
  quotation   Quotation @relation(fields: [quotationId], references: [id], onDelete: Cascade)
  productId   String?   @db.ObjectId
  product     Product?  @relation(fields: [productId], references: [id])
}
